{
  "name": "aptor",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-preserving work credential proofs on Midnight.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "contracts/*"
  ],
  "scripts": {
    "prebuild": "npm run contract:build",
    "build": "npm run build --workspace @aptor/web",
    "delivery:migrate": "npm run migrate --workspace @aptor/delivery",
    "delivery:test": "npm run test --workspace @aptor/delivery",
    "browser:e2e:prepare": "npm run contract:build && npm run build --workspace @aptor/browser && npm run midnight:build && node apps/web/e2e/prepare-local.mjs",
    "browser:test:local": "npm run midnight:network:up && npm run browser:e2e:prepare && npm run test:e2e:local --workspace @aptor/web; status=$?; npm run midnight:network:down; exit $status",
    "contract:build": "npm --prefix contracts/aptor-credential run build",
    "contract:compile": "npm --prefix contracts/aptor-credential run compact",
    "contract:test": "npm --prefix contracts/aptor-credential test",
    "contract:typecheck": "npm --prefix contracts/aptor-credential run typecheck",
    "predev": "npm run contract:build",
    "dev": "npm run dev --workspace @aptor/web",
    "predev:preprod": "npm run contract:build && npm run build --workspace @aptor/shared && npm run build --workspace @aptor/browser && npm run build --workspace @aptor/delivery && npm run zk:sync --workspace @aptor/web",
    "dev:preprod": "node scripts/start-preprod-deployment.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint --workspace @aptor/web",
    "midnight:build": "npm run build --workspace @aptor/midnight",
    "midnight:network:down": "npm run network:down --workspace @aptor/midnight",
    "midnight:network:health": "npm run network:health --workspace @aptor/midnight",
    "midnight:network:logs": "npm run network:logs --workspace @aptor/midnight",
    "midnight:network:up": "npm run network:up --workspace @aptor/midnight",
    "midnight:test:local": "npm run test:local --workspace @aptor/midnight",
    "midnight:test:network": "npm run test:network:local --workspace @aptor/midnight",
    "security:scan": "node scripts/security-scan.mjs",
    "release:bundle:check": "node scripts/verify-production-bundle.mjs",
    "release:smoke": "node scripts/smoke-production.mjs",
    "start:production": "npm run delivery:migrate && npm run start:production --workspace @aptor/web",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "next": "16.2.10",
    "prettier": "3.9.5"
  }
}
