# Public, non-secret local development endpoints.
MIDNIGHT_NETWORK_ID=undeployed
MIDNIGHT_INDEXER_URL=http://127.0.0.1:8088/api/v4/graphql
MIDNIGHT_INDEXER_WS_URL=ws://127.0.0.1:8088/api/v4/graphql/ws
MIDNIGHT_NODE_URL=http://127.0.0.1:9944
MIDNIGHT_NODE_WS_URL=ws://127.0.0.1:9944
MIDNIGHT_PROOF_SERVER_URL=http://127.0.0.1:6300

# Browser-facing public configuration. Local development uses "undeployed".
# The public release supports only LocalNet and Preprod.
NEXT_PUBLIC_APTOR_NETWORK=undeployed
NEXT_PUBLIC_APTOR_CONTRACT_ADDRESS=
NEXT_PUBLIC_APTOR_RPC_URL=http://127.0.0.1:9944
NEXT_PUBLIC_APTOR_INDEXER_URL=http://127.0.0.1:8088/api/v4/graphql
NEXT_PUBLIC_APTOR_INDEXER_WS_URL=ws://127.0.0.1:8088/api/v4/graphql/ws
NEXT_PUBLIC_APTOR_EXPLORER_URL=
NEXT_PUBLIC_APTOR_1AM_EXPLORER_URL=
NEXT_PUBLIC_APTOR_ZK_ARTIFACTS_URL=/zk/aptor
NEXT_PUBLIC_APTOR_ARTIFACT_FINGERPRINT=
NEXT_PUBLIC_APTOR_ENABLE_PREPROD_DEPLOYMENT=false

# Server-only delivery configuration. Use a persistent disk in production.
APTOR_DELIVERY_DB_PATH=.aptor-delivery/aptor.sqlite
APTOR_PUBLIC_URL=http://localhost:3000

# Optional landing-page HLS stream. The bundled local loop is used when unset.
NEXT_PUBLIC_APTOR_HLS_URL=
