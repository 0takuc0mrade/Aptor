{
  "name": "@aptor/delivery",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "types": "./dist/src/index.d.ts",
  "scripts": {
