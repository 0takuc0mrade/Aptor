    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aptor/shared": "0.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "6.0.3"
  }
